APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Optional SQL (only if a package needs it). Application data is in Firestore (FirestoreService).
# Default sqlite file: database/database.sqlite — create empty file or run migrations if required.
DB_CONNECTION=sqlite
# DB_DATABASE=  (omit to use database/database.sqlite)
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=hr_icecream
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Gmail SMTP (for OTP emails, receipts). Do NOT set MAIL_URL - it overrides the vars below.
# App Password: https://myaccount.google.com/apppasswords (requires 2FA). Use 16 chars, no spaces.
# Option A (STARTTLS): MAIL_MAILER=smtp, MAIL_PORT=587, MAIL_ENCRYPTION=tls
# Option B (SSL, often works if 587 fails on Windows): MAIL_MAILER=gmail, MAIL_PORT=465, MAIL_ENCRYPTION=ssl
MAIL_MAILER=gmail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="your-gmail@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google OAuth (Sign in with Google on login/register)
# Get credentials from https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 Client ID (Web application). APP_URL below must match the URL you use in the browser. In Google Console, add these Authorized redirect URIs (use your actual APP_URL):
#   {APP_URL}/customer/auth/google/callback
#   {APP_URL}/admin/auth/google/callback
# For local dev with Google sign-in use APP_URL=http://127.0.0.1:8000 (Google does not allow private IPs like 10.x or 192.168.x).
# For Flutter Android: create an Android OAuth 2.0 Client ID and set GOOGLE_ANDROID_CLIENT_ID so the API can verify id_token from the app.
# For Flutter iOS: set GOOGLE_IOS_CLIENT_ID to the iOS OAuth client ID (API verifies Google OAuth JWT audience).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=

# Firebase Admin SDK (required for Realtime Database + Firestore)
# Download service account JSON from Firebase Console > Project settings > Service accounts
FIREBASE_CREDENTIALS=storage/app/firebase/your-project-firebase-adminsdk.json

# Firebase Realtime Database URL (keep for current real-time chat/notifications usage)
FIREBASE_DATABASE_URL=

# Firebase Web app config (Firestore real-time signals for admin layout). Console → Project settings → Your apps → Web app.
# If set, the admin UI listens to Firestore doc admin_signals/broadcast (see mergeAdminBroadcast). Still set FIREBASE_DATABASE_URL for RTDB chat sync.
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_WEB_STORAGE_BUCKET=
FIREBASE_WEB_MESSAGING_SENDER_ID=
FIREBASE_WEB_APP_ID=

# Optional: explicit Firestore/Google Cloud project id (usually inferred from service account)
GOOGLE_CLOUD_PROJECT=

# Maps: "google" (paid/billing) or "osm" (free: Nominatim + OSRM + OSM tiles — OK for student / light testing).
MAPS_PROVIDER=google

# Google Maps Platform (only when MAPS_PROVIDER=google)
# Create one key with Geocoding API + Directions API enabled (server IP / referrer restrictions).
# Optional GOOGLE_MAPS_CLIENT_KEY: Android/iOS key for google_maps_flutter (package + SHA-1 restrictions).
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_CLIENT_KEY=

# OpenStreetMap stack (only when MAPS_PROVIDER=osm)
# Nominatim: set OSM_NOMINATIM_EMAIL to your contact (usage policy). Do not hammer the public server.
OSM_NOMINATIM_URL=https://nominatim.openstreetmap.org
OSM_OSRM_URL=https://router.project-osrm.org
OSM_NOMINATIM_EMAIL=
# Identify your app (Nominatim / OSRM etiquette)
OSM_HTTP_USER_AGENT=HR-IceCream-API/1.0
# flutter_map TileLayer URL; default OSMF tile usage policy applies.
OSM_TILE_URL_TEMPLATE=https://tile.openstreetmap.org/{z}/{x}/{y}.png
OSM_TILE_ATTRIBUTION=© OpenStreetMap contributors

# If Firestore fails with "cURL error 28" / timeout to oauth2.googleapis.com: fix outbound HTTPS (firewall, DNS, VPN).
# Corporate proxy: set your proxy URL, then uncomment (Kreait Firebase reads this):
# FIREBASE_HTTP_CLIENT_PROXY=http://user:pass@proxy-host:8080
# Optional: increase seconds (default is package default; only helps slow networks, not blocked connections)
# FIREBASE_HTTP_CLIENT_TIMEOUT=60
